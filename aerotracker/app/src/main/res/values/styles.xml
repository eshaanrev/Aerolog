<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================ Cards =================================== -->
    <style name="Widget.Aerotracker.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/color_surface</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeColor">@color/color_outline</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>

    <!-- ============================ Buttons ================================= -->
    <style name="Widget.Aerotracker.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/color_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size_button</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:insetTop">@dimen/inset_none</item>
        <item name="android:insetBottom">@dimen/inset_none</item>
        <item name="iconTint">@color/white</item>
        <item name="iconGravity">textStart</item>
    </style>

    <style name="Widget.Aerotracker.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/color_accent</item>
        <item name="strokeColor">@color/color_accent</item>
        <item name="iconTint">@color/color_accent</item>
        <item name="rippleColor">@color/ripple_light</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size_button</item>
        <item name="android:insetTop">@dimen/inset_none</item>
        <item name="android:insetBottom">@dimen/inset_none</item>
    </style>

    <style name="Widget.Aerotracker.Button.Destructive" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/color_error</item>
        <item name="strokeColor">@color/color_error</item>
        <item name="iconTint">@color/color_error</item>
        <item name="rippleColor">@color/ripple_light</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size_button</item>
        <item name="android:insetTop">@dimen/inset_none</item>
        <item name="android:insetBottom">@dimen/inset_none</item>
    </style>

    <style name="Widget.Aerotracker.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/color_accent</item>
        <item name="rippleColor">@color/ripple_light</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size_button</item>
    </style>

    <!-- ============================ Inputs ================================== -->
    <style name="Widget.Aerotracker.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/field_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/field_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/field_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/field_corner_radius</item>
        <item name="boxStrokeColor">@color/color_primary</item>
        <item name="hintTextColor">@color/color_primary</item>
        <item name="android:textColorHint">@color/color_text_secondary</item>
        <item name="boxStrokeErrorColor">@color/color_error</item>
        <item name="errorTextColor">@color/color_error</item>
        <item name="errorIconTint">@color/color_error</item>
        <item name="endIconTint">@color/color_text_secondary</item>
    </style>

    <!-- ============================ Text appearances ======================== -->
    <style name="TextAppearance.Aerotracker.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">@dimen/text_size_headline</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <style name="TextAppearance.Aerotracker.CardTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_size_card_title</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <style name="TextAppearance.Aerotracker.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/color_text_secondary</item>
    </style>

    <style name="TextAppearance.Aerotracker.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/color_text_secondary</item>
    </style>

    <!-- ============================ Badges (chips) ========================== -->
    <!-- Pill-shaped status / verdict badge. Background + text colors are applied
         programmatically in Java; this style fixes the shape, size and typography. -->
    <style name="Widget.Aerotracker.Badge" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">@dimen/badge_corner_radius</item>
        <item name="chipMinHeight">@dimen/badge_min_height</item>
        <item name="chipStartPadding">@dimen/badge_padding_h</item>
        <item name="chipEndPadding">@dimen/badge_padding_h</item>
        <item name="android:textSize">@dimen/text_size_badge</item>
        <item name="android:textStyle">bold</item>
        <item name="chipIconVisible">false</item>
        <item name="chipStrokeWidth">@dimen/inset_none</item>
        <item name="ensureMinTouchTargetSize">false</item>
        <item name="android:checkable">false</item>
        <item name="android:clickable">false</item>
    </style>

    <style name="Widget.Aerotracker.Badge.Verdict">
        <item name="android:textSize">@dimen/text_size_verdict</item>
        <item name="chipMinHeight">@dimen/space_40</item>
    </style>
</resources>
