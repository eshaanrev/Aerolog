<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.aerotracker.fragment.LoginFragment"
        android:label="AeroTracker"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_history"
            app:destination="@id/launchHistoryFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_onboarding"
            app:destination="@id/onboardingFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.example.aerotracker.fragment.OnboardingFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_onboarding" />

    <fragment
        android:id="@+id/launchHistoryFragment"
        android:name="com.example.aerotracker.fragment.LaunchHistoryFragment"
        android:label="Launch History"
        tools:layout="@layout/fragment_launch_history">
        <action
            android:id="@+id/action_history_to_new_launch"
            app:destination="@id/newLaunchFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_history_to_detail"
            app:destination="@id/newLaunchFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_history_to_settings"
            app:destination="@id/settingsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/newLaunchFragment"
        android:name="com.example.aerotracker.fragment.NewLaunchFragment"
        android:label="Launch"
        tools:layout="@layout/fragment_new_launch">
        <argument
            android:name="isEditable"
            app:argType="boolean"
            android:defaultValue="true" />
        <argument
            android:name="launchId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.aerotracker.fragment.SettingsFragment"
        android:label="Profile &amp; Settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_logout"
            app:destination="@id/loginFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>
