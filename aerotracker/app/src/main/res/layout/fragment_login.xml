<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="@dimen/screen_margin"
        android:paddingEnd="@dimen/screen_margin"
        android:paddingTop="@dimen/space_32"
        android:paddingBottom="@dimen/space_32">

        <!-- Brand block, top third -->
        <Space
            android:layout_width="wrap_content"
            android:layout_height="@dimen/space_48" />

        <ImageView
            android:layout_width="@dimen/login_logo_size"
            android:layout_height="@dimen/login_logo_size"
            android:src="@drawable/ic_rocket"
            android:contentDescription="Aerolog rocket logo"
            android:layout_marginBottom="@dimen/space_16" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aerolog"
            android:textSize="@dimen/text_size_logo"
            android:textStyle="bold"
            android:textColor="@color/color_primary"
            android:layout_marginBottom="@dimen/space_8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your rocket. Your data."
            android:textSize="@dimen/text_size_button"
            android:textStyle="italic"
            android:textColor="@color/color_text_secondary"
            android:layout_marginBottom="@dimen/space_48" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/email_layout"
            style="@style/Widget.Aerotracker.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email"
            app:errorEnabled="true"
            android:layout_marginBottom="@dimen/space_16">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/email_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/touch_target_min"
                android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/password_layout"
            style="@style/Widget.Aerotracker.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password"
            app:errorEnabled="true"
            app:endIconMode="password_toggle"
            android:layout_marginBottom="@dimen/space_8">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/password_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/touch_target_min"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Connection / generic auth errors (field errors use helper text). -->
        <TextView
            android:id="@+id/auth_error_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/color_error"
            android:textSize="@dimen/text_size_body"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/space_8" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/auth_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="@color/color_accent"
            android:layout_marginBottom="@dimen/space_8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sign_in_btn"
            style="@style/Widget.Aerotracker.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign In"
            android:layout_marginTop="@dimen/space_16"
            android:layout_marginBottom="@dimen/space_8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/register_btn"
            style="@style/Widget.Aerotracker.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account" />

        <Space
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</ScrollView>
